{
  "name": "simple-thermostat",
  "version": "4.0.0",
  "description": "A different take on the thermostat card for Home Assistant Lovelace UI",
  "main": "simple-thermostat.js",
  "type": "module",
  "repository": "git@github.com:Wheemer/simple-thermostat.git",
  "author": "Raymond Julin <raymond.julin@gmail.com> (original), Wheemer (maintainer)",
  "license": "MIT",
  "files": [
    "simple-thermostat.js",
    "src"
  ],
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "crypto-browserify": "^3.3.0",
    "debounce-fn": "^6.0.0",
    "lit": "^3.0.0",
    "rollup-plugin-node-polyfills": "^0.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "marked": "^18.0.4",
    "postcss": "^8.4.49",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.4.2",
    "rollup": "^4.28.1",
    "rollup-plugin-inject-process-env": "^1.3.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-postcss-lit": "^2.1.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "jest",
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider rollup -c",
    "build:prod": "cross-env NODE_ENV=production BUILD_TARGET=prod rollup -c",
    "build:debug": "cross-env BUILD_TARGET=debug rollup -c",
    "render:readme": "node scripts/render-readme-preview.mjs",
    "postversion": "npm run build",
    "dev": "concurrently 'npm:dev:*'",
    "dev:build": "cross-env BUILD_TARGET=debug rollup -c --watch",
    "dev:test": "jest --watchAll",
    "typecheck": "tsc --noEmit"
  },
  "prettier": {
    "printWidth": 80,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  }
}
